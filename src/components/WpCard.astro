---
interface Props {
  title: string;
  url: string;
  date: string;
  tags?: string[];
}

const { title, date, url, tags } = Astro.props;
---

<div class="wp-article">
  <p class="date">{date}</p>
  <h4><a href={url}>{title}</a></h4>
  {tags.map((tag) => <span class="tag">{tag}</span>)}
</div>
<style>
  .wp-article {
    margin-bottom: 2rem;
  }

  .wp-article > h4 {
    margin: 2px 0 4px 0px;
  }

  .date {
    margin: 0 0;
    color: gray;
    font-size: small;
  }

  .wp-article > h4 > a {
    text-decoration: none;
  }

  .tag {
    padding: 2px 4px;
    border-radius: 2px;
    background-color: #fafafa;
    font-size: x-small;
    margin-right: 0.5rem;
  }

  @media (prefers-color-scheme: dark) {
    .tag {
      background-color: #2f3e46;
    }
  }
</style>
